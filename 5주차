function kgy_23010898_2()

  
    name = input('학생 이름을 입력하시오: ', 's');

    
    scores = input('국어, 영어, 수학 점수를 벡터로 입력하시오: ');

  
    avg = mean(scores);
    fprintf('이름: %s\n', name);
    fprintf('세 과목 점수: %d %d %d\n', scores(1), scores(2), scores(3));
    fprintf('평균: %.2f\n', avg);

    if avg >= 90
        fprintf('등급: Excellent\n');
    elseif avg >= 80
        fprintf('등급: Good\n');
    elseif avg >= 70
        fprintf('등급: Fair\n');
    else
        fprintf('등급: Needs Improvement\n');
    end
end

