function kgy_23010898_3()

    applicants = [165 72 1;
                  172 85 0;
                  168 91 1;
                  181 77 1;
                  174 69 0;
                  169 88 1];

   
    tall = applicants(:,1) >= 170;
    disp('(1) 키 170 이상 논리 배열:');
    disp(tall);
  
    highScore = applicants(:,2) >= 80;
    disp('(2) 시험점수 80 이상 논리 배열:');
    disp(highScore);

    passed = applicants(:,3) == 1;
    disp('(3) 면접 통과자 논리 배열:');
    disp(passed);

    finalIdx = find(tall & highScore & passed);
    disp('(4) 최종 합격자 행 번호:');
    disp(finalIdx);

    disp('(5) 최종 합격자 정보 [행번호, 키, 시험점수, 면접통과여부]:');
    finalInfo = [finalIdx, applicants(finalIdx, :)];
    disp(finalInfo);
end



