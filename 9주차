%2
figure
clear; clc
x = 1:1:50;
y = 3.^x;

subplot(1,2,1)
plot(x, y)
title('일반 plot'), xlabel('x'), ylabel('y'), grid on

subplot(1,2,2)
semilogy(x, y)
title('semilogy'), xlabel('x'), ylabel('y'), grid on

% 설명: 일반 plot은 y값이 급격히 커져 초반 값이 거의 보이지 않음.
% semilogy는 y축을 로그 스케일로 표시하여 전 구간에서
% 지수 성장의 선형적 증가 패턴을 명확하게 볼 수 있음.

%3
figure
clear; clc
score = [72,85,91,66,78,88,95,54,60,73,82,90,69,77,84,92,58,63,79,87];

% score.dat으로 저장 후 불러오기
