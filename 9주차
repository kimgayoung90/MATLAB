%7
figure

clear; clc
[X, Y] = meshgrid(-4:0.1:4, -4:0.1:4);
Z = X.^2 - Y.^2;

mesh(X, Y, Z)
title('z = x^2 - y^2')
xlabel('x'), ylabel('y'), zlabel('z'), grid on

% 설명: z = x²-y²는 saddle surface(안장면)임.
% x 방향으로는 위로 볼록, y 방향으로는 아래로 볼록한
% 말안장 모양의 곡면이 나타남.

%8
figure

clear; clc

[X, Y] = meshgrid(-2*pi:0.1:2*pi, -2*pi:0.1:2*pi);
Z = sin(X) .* cos(Y);

subplot(1,2,1)
mesh(X, Y, Z)
title('mesh: z = sin(x)cos(y)')
xlabel('x'), ylabel('y'), zlabel('z')

subplot(1,2,2)
contour(X, Y, Z, 20)
title('contour: z = sin(x)cos(y)')
xlabel('x'), ylabel('y'), grid on

% 설명: contour 그래프는 등고선을 통해 z값이 같은
% (x,y) 위치를 2D로 보여줌. 함수의 최대/최솟값 위치와
% 주기적 패턴을 평면에서 파악하기 쉬움.

%9

figure
clear; clc
t = 0:0.01:25;
y = exp(-0.15*t) .* cos(4*t);

% (a) 일반 plot
subplot(1,3,1)
plot(t, y)
title('y(t) 일반 plot')
xlabel('t'), ylabel('y(t)'), grid on

% (b) envelope 함께 표시
subplot(1,3,2)
plot(t, y, t, exp(-0.15*t), 'r--', t, -exp(-0.15*t), 'r--')
title('envelope 포함')
xlabel('t'), ylabel('y(t)')
legend('y(t)','위 envelope','아래 envelope'), grid on

% (c) |y(t)| semilogy
subplot(1,3,3)
semilogy(t, abs(y))
title('|y(t)| semilogy')
xlabel('t'), ylabel('|y(t)|'), grid on

% 설명: 로그 스케일에서 감쇠 진동의 포락선이
% 직선으로 나타나 감쇠율을 명확히 확인할 수 있음.


%10

figure

clear; clc
[X, Y] = meshgrid(-6:0.1:6, -6:0.1:6);
Z = cos(X) .* sin(Y) .* exp(-0.05*(X.^2 + Y.^2));

% (a) mesh
subplot(1,2,1)
mesh(X, Y, Z)
title('mesh: z = cos(x)sin(y)e^{-0.05(x²+y²)}')
xlabel('x'), ylabel('y'), zlabel('z')

% (b) contour
subplot(1,2,2)
contour(X, Y, Z, 20)
title('contour'), xlabel('x'), ylabel('y'), grid on

% (c) max 값과 위치 추정
[max_val, idx] = max(Z(:));
[row, col] = ind2sub(size(Z), idx);
fprintf('최대값: %.4f\n', max_val)
fprintf('위치: x = %.2f, y = %.2f\n', X(row,col), Y(row,col))

%11

figure

clear; clc
t = [0, 1, 2, 3, 4, 5, 6];
C = [12, 8.9, 6.6, 4.9, 3.6, 2.7, 2.0];

% (a) 일반 plot
subplot(1,2,1)
plot(t, C, 'o-')
title('C(t) 일반 plot')
xlabel('t'), ylabel('C(t)'), grid on

% (b) semilogy
subplot(1,2,2)
semilogy(t, C, 'o-')
title('C(t) semilogy')
xlabel('t'), ylabel('C(t)'), grid on

% (c) k 추정: log C = log C0 - kt → 선형 회귀
