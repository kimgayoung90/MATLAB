clear; clc;
rng(12);

t = (1:120)';
signal = 30 + 4*sin(t/8) + randn(120, 1);

signal([15, 45, 90]) = NaN;

signal(30) = 80;
signal(75) = -20;
signal(110) = 95;

idxMissing = isnan(signal);
numMissing = sum(idxMissing);

fillValue = mean(signal, 'omitnan');
signalFilled = signal;
signalFilled(idxMissing) = fillValue;

muSignal = mean(signalFilled);
sigSignal = std(signalFilled);

idxOutlier = abs(signalFilled - muSignal) > 3*sigSignal;

signalClean = signalFilled;
signalClean(idxOutlier) = NaN;

validSignal = signalClean(~isnan(signalClean));

normSignal = (validSignal - min(validSignal)) ./ ...
             (max(validSignal) - min(validSignal));

finalMean = mean(normSignal);
finalVar = var(normSignal);

figure;
tiledlayout(2, 1);

nexttile;
plot(validSignal, '-o');
xlabel('Index');
ylabel('validSignal');
title('Valid Signal');
grid on;

nexttile;
plot(normSignal, '-s');
xlabel('Index');
ylabel('normSignal');
title('Normalized Signal');
grid on;


