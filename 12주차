clear; clc;

x = -5:0.05:5;
y = -5:0.05:5;

[X, Y] = meshgrid(x, y);

Z = exp(-0.08*(X.^2 + Y.^2)) .* sin(3*X) .* cos(2*Y) ...
    + 0.15*sin(X.*Y);

figure;
surf(X, Y, Z, 'DisplayName', 'Surface');
shading interp;
colorbar;

xlabel('x-axis');
ylabel('y-axis');
zlabel('z=f(x,y)');
title('Detailed Surface Plot of a Multivariable Function');

grid on;
set(gca, 'FontSize', 12);
view(45, 30);
hold on;

Z0 = zeros(size(Z));
surf(X, Y, Z0, ...
    'FaceAlpha', 0.25, ...
    'EdgeColor', 'none', ...
    'DisplayName', 'z=0 plane');

maxZ = max(Z, [], 'all');
minZ = min(Z, [], 'all');

[rowMax, colMax] = find(Z == maxZ, 1);
[rowMin, colMin] = find(Z == minZ, 1);

maxPoint = [X(rowMax, colMax), Y(rowMax, colMax), maxZ];
minPoint = [X(rowMin, colMin), Y(rowMin, colMin), minZ];

plot3(maxPoint(1), maxPoint(2), maxPoint(3), ...
    'o', 'MarkerSize', 10, 'MarkerFaceColor', 'r', ...
    'DisplayName', 'Maximum point');

plot3(minPoint(1), minPoint(2), minPoint(3), ...
    's', 'MarkerSize', 10, 'MarkerFaceColor', 'b', ...
    'DisplayName', 'Minimum point');

legend('Surface', 'z=0 plane', 'Maximum point', 'Minimum point');

saveas(gcf, 'complex_surface.png');
