%% 12
clear; clc
epoch = [1 2 5 10 20 50 100 200];
loss = [3.1 2.4 1.7 1.2 0.83 0.36 0.14 0.06];

figure
plot(epoch,loss,'o-')
grid on
xlabel('epoch')
ylabel('loss')
title('plot')

figure
semilogy(epoch,loss,'o-')
grid on
xlabel('epoch')
ylabel('loss')
title('semilogy')

r = loss(2:end)./loss(1:end-1);
avg_r = mean(r);

disp(r)
disp(avg_r)

if avg_r < 1
    disp('평균 비율이 1보다 작으므로 loss가 전반적으로 감소한다.')
else
    disp('평균 비율이 1보다 크거나 같으므로 loss가 전반적으로 감소한다고 보기 어렵다.')
end
