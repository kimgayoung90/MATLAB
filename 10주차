[rowMin,colMin] = ind2sub(size(Z),idxMin);

fprintf('최대값 = %.6f, x = %.2f, y = %.2f\n', maxZ, x(colMax), y(rowMax))
fprintf('최소값 = %.6f, x = %.2f, y = %.2f\n', minZ, x(colMin), y(rowMin))

