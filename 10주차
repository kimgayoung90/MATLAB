%% 8

figure

clear; clc
t = 0:0.01:24;
P = 50 + 18*sin(pi*t/12) + 6*cos(pi*t/4);

plot(t,P)
grid on
xlabel('t(hour)')
ylabel('P(t)')

[maxP, idxMax] = max(P);
[minP, idxMin] = min(P);

hold on
plot(t(idxMax),maxP,'ro','MarkerFaceColor','r')
