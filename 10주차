%% 1

t = 0:0.01:30;
f = exp(-0.12*t).*sin(5*t) + 0.3*cos(2*t);
u = exp(-0.12*t) + 0.3;
l = -exp(-0.12*t) - 0.3;

idx = find(f(2:end-1) > f(1:end-2) & f(2:end-1) > f(3:end)) + 1;

plot(t,f,'b'); hold on
plot(t,u,'r--',t,l,'r--')
plot(t(idx),f(idx),'ko','MarkerFaceColor','y')
grid on
legend('f(t)','u(t)','l(t)','local max')
result1 = table(t(idx)', f(idx)', 'VariableNames', {'t','f'});
disp(result1)

%% 2
clear; clc
x = -5:0.05:5;
y = -5:0.05:5;
[X,Y] = meshgrid(x,y);
Z = sin(X.*Y)./(1 + X.^2 + Y.^2);

figure
mesh(X,Y,Z)
xlabel('x'); ylabel('y'); zlabel('z')
title('문제 2 mesh 그래프')

figure
contour(X,Y,Z,25)
colorbar
xlabel('x'); ylabel('y')
title('문제 2 등고선 그래프')

absZ = abs(Z);
maxAbsZ = max(absZ(:));
idx = find(absZ == maxAbsZ);
[row,col] = ind2sub(size(absZ),idx);
fprintf('|Z| 최대값 = %.6f\n', maxAbsZ)
fprintf('x = %.2f, y = %.2f\n', x(col), y(row))

