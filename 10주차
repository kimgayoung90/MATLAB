%% 6
clear; clc
x = -6:0.05:6;
y = -6:0.05:6;
[X,Y] = meshgrid(x,y);
Z = exp(-0.08*(X.^2 + Y.^2)).*cos(3*X).*sin(2*Y);

figure
surf(X,Y,Z)
xlabel('x'); ylabel('y'); zlabel('z')
title('문제 6 surf 그래프')

figure
contour(X,Y,Z,30)
