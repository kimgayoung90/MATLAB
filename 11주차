clear; clc

Machine = ["M1";"M2";"M3";"M4";"M5";"M6";"M7";"M8";"M9";"M10"];
Vibration = [1.8;2.4;1.5;3.1;2.7;1.9;3.5;2.2;1.6;2.9];
