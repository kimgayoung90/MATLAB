% 8번

clear ,clc

price = [19, 18, 22, 21, 25, 19, 17, 21, 27, 29];

cash = 1000000;      % 초기 자본
shares = 0;          % 보유 주식 수
buy_total = 0;       % 총 매수 금액
sell_total = 0;      % 총 매도 금액

for i = 1:length(price)-1
    if price(i+1) > price(i)
        % 오늘 매수
        buy_amount = price(i) * 100;
        cash = cash - buy_amount;
        shares = shares + 100;
        buy_total = buy_total + buy_amount;
    elseif price(i+1) < price(i)
        % 오늘 매도
        sell_amount = price(i) * 100;
        cash = cash + sell_amount;
        shares = shares - 100;
        sell_total = sell_total + sell_amount;
    end
end

portfolio_value = cash + shares * price(end);

fprintf('(a) 총 매수 금액 = %d원\n', buy_total);
fprintf('(b) 총 매도 금액 = %d원\n', sell_total);
fprintf('(c) 10일째 보유 주식 수 = %d주\n', shares);
fprintf('(d) 포트폴리오 가치 = %d원\n', portfolio_value);

% 9번

clear ,clc
mode = input('연결 방식 입력 (serial / parallel): ', 's');
n = input('저항의 개수 n을 입력하세요: ');

R = zeros(1, n);
for i = 1:n
    R(i) = input(sprintf('R(%d) = ', i));
end

switch mode
    case 'serial'
        Req = 0;
        for i = 1:n
            Req = Req + R(i);
        end
        fprintf('직렬 등가저항 = %.4f\n', Req);

    case 'parallel'
        sum_inv = 0;
        for i = 1:n
            sum_inv = sum_inv + 1 / R(i);
        end
        Req = 1 / sum_inv;
        fprintf('병렬 등가저항 = %.4f\n', Req);

end
