% 5번
clear ,clc
a = input('a를 입력하세요: ');
b = input('b를 입력하세요: ');
cmd = input('명령어를 입력하세요 (add, sub, mul, div): ', 's');

switch cmd
    case 'add'
        result = a + b;
        fprintf('결과 = %.4f\n', result);

    case 'sub'
        result = a - b;
        fprintf('결과 = %.4f\n', result);

    case 'mul'
        result = a * b;
        fprintf('결과 = %.4f\n', result);

    case 'div'
        if b == 0
            disp('division by zero')
        else
            result = a / b;
            fprintf('결과 = %.4f\n', result);
        end

    otherwise
        disp('invalid command')
end

