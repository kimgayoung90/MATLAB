%% Problem 9
clear; clc;

N = 50000;

stage1 = rand(N,1) < 0.94;

stage2 = false(N,1);

idx1 = find(stage1);

stage2(idx1) = rand(length(idx1),1) < 0.91;

stage3 = false(N,1);

idx2 = find(stage2);

stage3(idx2) = rand(length(idx2),1) < 0.88;

finalPass = stage3;

passRate = mean(finalPass);

fprintf('최종 합격률 = %.6f\n',passRate);

fail1 = sum(~stage1);
fail2 = sum(stage1 & ~stage2);
fail3 = sum(stage2 & ~stage3);
passFinal = sum(finalPass);

figure;
bar([fail1 fail2 fail3 passFinal]);
xticklabels({'Stage1 Fail','Stage2 Fail','Stage3 Fail','Pass'});
title('Inspection Results');


%% Problem 10
clear; clc;

loadVariation = 35*randn(10000,1);

overload = rand(10000,1) < 0.12;

powerUsage = 500 + loadVariation + 120*overload;

ratio = mean(powerUsage > 650);

fprintf('650 초과 비율 = %.6f\n',ratio);

