%% Problem 4
clear; clc;

orders = poissrnd(180,365,1);

totalTime = zeros(365,1);

for i = 1:365

    t = 6 + 2*randn(orders(i),1);

    t(t<0) = 0;

    totalTime(i) = sum(t);

end

ratio = mean(totalTime > 1200);

fprintf('1200분 초과 비율 = %.4f\n',ratio);

figure;
plot(orders);
title('Daily Orders');

figure;
plot(totalTime);
title('Daily Processing Time');

figure;
scatter(orders,totalTime);
xlabel('Orders');
ylabel('Total Time');
title('Orders vs Processing Time');

